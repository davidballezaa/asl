POSTGRES_USER=asl
POSTGRES_PASSWORD=localdev
POSTGRES_DB=asl

DATABASE_URL=postgresql+asyncpg://asl:localdev@127.0.0.1:5432/asl
DB_BACKEND=sql
JWT_SECRET=local-dev-secret
CORS_ORIGINS=http://localhost:8081,http://localhost:19006,http://127.0.0.1:8081
RECOGNIZER_IMPL=stub

# Production (docker compose + Caddy)
# API_DOMAIN=api.yourdomain.com
# POSTGRES_PASSWORD=strong-password-here

# SQLite alternative (no Docker)
# DATABASE_URL=sqlite+aiosqlite:///./asl.db
